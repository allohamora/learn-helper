{
  "name": "learn-helper",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc -p ./tsconfig.build.json",
    "postbuild": "tsc-alias -p ./tsconfig.build.json"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@types/node": "^22.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "ultracite": "^5.3.8"
  },
  "engines": {
    "node": ">=v22.13.0",
    "npm": ">=10.9.2"
  },
  "packageManager": "npm@10.9.2",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": "ultracite fix"
  }
}
